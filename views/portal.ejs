<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Portal | Elimu-Connect</title>
    <style>
        :root { --primary: #1a508b; --secondary: #1e40af; --bg: #f8fafc; --success: #10b981; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); margin: 0; padding: 20px; }
        .container { max-width: 900px; margin: auto; background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
        .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #eee; padding-bottom: 15px; margin-bottom: 25px; }
        
        h3 { color: var(--primary); border-left: 5px solid var(--primary); padding-left: 10px; }
        .form-group { margin-bottom: 15px; display: flex; flex-direction: column; }
        label { font-weight: bold; margin-bottom: 5px; font-size: 0.9rem; color: #475569; }
        select, input { padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 1rem; }
        
        .submit-btn { background: var(--primary); color: white; padding: 15px; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; transition: 0.3s; }
        .submit-btn:hover { background: var(--secondary); transform: translateY(-2px); }

        /* Manage Section Table */
        .manage-table { width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 0.9rem; }
        .manage-table th, .manage-table td { padding: 12px; border: 1px solid #edf2f7; text-align: left; }
        .manage-table th { background: #f7fafc; color: #4a5568; }
        .badge { padding: 4px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: bold; text-transform: uppercase; }
        .b-pdf { background: #fee2e2; color: #dc2626; }
        .b-vid { background: #dbeafe; color: #2563eb; }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <div>
            <h2 style="margin:0;"><%= user.fullname %></h2>
            <p style="margin:0; color:#64748b;">Teacher Dashboard</p>
        </div>
        <a href="/logout" style="color: #ef4444; font-weight:bold; text-decoration:none;">Logout</a>
    </div>

    <% if(msg) { %>
        <div style="background: #dcfce7; color: #166534; padding: 15px; border-radius: 8px; margin-bottom: 20px; text-align: center; font-weight: bold;">
            <%= msg %>
        </div>
    <% } %>

    <h3>Upload New CBC Material</h3>
    <form action="/submit-material" method="POST" enctype="multipart/form-data">
        <div class="form-group">
            <label>1. Select Grade</label>
            <select name="grade" id="gradeSelector" required>
                <option value="">-- Choose Grade --</option>
                <optgroup label="Lower Primary"><option value="1">Grade 1</option><option value="2">Grade 2</option><option value="3">Grade 3</option></optgroup>
                <optgroup label="Upper Primary"><option value="4">Grade 4</option><option value="5">Grade 5</option><option value="6">Grade 6</option></optgroup>
                <optgroup label="Junior School"><option value="7">Grade 7</option><option value="8">Grade 8</option><option value="9">Grade 9</option></optgroup>
            </select>
        </div>

        <div class="form-group">
            <label>2. Select Learning Area (Subject)</label>
            <select name="subject" id="subjectSelector" required disabled>
                <option value="">-- Select Grade First --</option>
            </select>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
            <div class="form-group">
                <label>3. Resource Type</label>
                <select name="type" required>
                    <option value="PDF">PDF Notes</option>
                    <option value="Video">Video Lesson</option>
                    <option value="Audio">Audio Narration</option>
                    <option value="Quiz">Interactive Quiz</option>
                    <option value="Project">Project Guide</option>
                </select>
            </div>
            <div class="form-group">
                <label>4. Select File</label>
                <input type="file" name="materialFile" required>
            </div>
        </div>

        <button type="submit" class="submit-btn">🚀 Upload to Student Portal</button>
    </form>

    <hr style="margin: 40px 0; border: 0; border-top: 2px solid #eee;">

    <h3>Manage My Uploads</h3>
<table class="manage-table">
    <thead>
        <tr>
            <th>Subject</th>
            <th>Grade</th>
            <th>Type</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% if (teacherMaterials.length > 0) { %>
            <% teacherMaterials.forEach(item => { %>
                <tr>
                    <td><%= item.subject_name %></td>
                    <td>Grade <%= item.grade %></td>
                    <td><span class="badge b-pdf"><%= item.material_type %></span></td>
                    <td>
                        <a href="/edit-material/<%= item.id %>" style="color: #1a508b; margin-right: 10px;">Edit</a>
                        <a href="/delete-material/<%= item.id %>" 
                           style="color: #ef4444;" 
                           onclick="return confirm('Are you sure you want to delete this resource?')">Delete</a>
                    </td>
                </tr>
            <% }); %>
        <% } else { %>
            <tr><td colspan="4" style="text-align:center;">You haven't uploaded anything yet.</td></tr>
        <% } %>
    </tbody>
</table>
</div>

<script>
    // 2024 Rationalized CBC Subject Mapping
    const cbcMapping = {
        lower: ["English Activities", "Kiswahili Activities", "Mathematical Activities", "Environmental Activities", "Religious Education", "Creative Activities"],
        upper: ["English", "Kiswahili", "Mathematics", "Science and Technology", "Agriculture and Nutrition", "Social Studies", "Religious Education", "Creative Arts"],
        junior: ["English", "Kiswahili", "Mathematics", "Integrated Science", "Pre-Technical Studies", "Social Studies", "Agriculture and Nutrition", "Religious Education", "Creative Arts and Sports", "Computer Science", "Health Education"]
    };

    const gradeSelector = document.getElementById('gradeSelector');
    const subjectSelector = document.getElementById('subjectSelector');

    gradeSelector.addEventListener('change', function() {
        const grade = parseInt(this.value);
        let subjects = [];

        if (grade >= 1 && grade <= 3) subjects = cbcMapping.lower;
        else if (grade >= 4 && grade <= 6) subjects = cbcMapping.upper;
        else if (grade >= 7 && grade <= 9) subjects = cbcMapping.junior;

        subjectSelector.innerHTML = '<option value="">-- Select Subject --</option>';
        if (subjects.length > 0) {
            subjectSelector.disabled = false;
            subjects.forEach(sub => {
                const option = document.createElement('option');
                option.value = sub;
                option.textContent = sub;
                subjectSelector.appendChild(option);
            });
        } else {
            subjectSelector.disabled = true;
        }
    });
</script>
</body>
</html>